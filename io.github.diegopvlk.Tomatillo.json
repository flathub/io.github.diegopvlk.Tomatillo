{
	"id": "io.github.diegopvlk.Tomatillo",
	"runtime": "org.gnome.Platform",
	"runtime-version": "49",
	"sdk": "org.gnome.Sdk",
	"command": "tomatillo",
	"finish-args": [
		"--share=ipc",
		"--socket=fallback-x11",
		"--device=dri",
		"--socket=wayland",
		"--socket=pulseaudio"
	],
	"cleanup": [
		"/include",
		"/lib/pkgconfig",
		"/man",
		"/share/doc",
		"/share/gtk-doc",
		"/share/man",
		"/share/pkgconfig",
		"*.la",
		"*.a"
	],
	"modules": [
		{
			"name": "libportal",
			"buildsystem": "meson",
			"config-opts": ["-Ddocs=false", "-Dvapi=false"],
			"sources": [
				{
					"type": "git",
					"url": "https://github.com/flatpak/libportal",
					"tag": "0.9.1",
					"commit": "8f5dc8d192f6e31dafe69e35219e3b707bde71ce"
				}
			]
		},
		{
			"name": "tomatillo",
			"builddir": true,
			"buildsystem": "meson",
			"sources": [
				{
					"type": "git",
					"url": "https://github.com/diegopvlk/Tomatillo",
					"tag": "v1.0.2",
					"commit": "76624a14a07cb7f6226c488354adae67dc55b20e",
					"x-checker-data": {
						"type": "git",
						"tag-pattern": "^v([\\d.]+)$"
					} 
				}
			]
		}
	]
}
